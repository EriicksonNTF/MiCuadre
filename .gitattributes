# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.ts text
*.tsx text
*.js text
*.jsx text
*.mjs text
*.cjs text

# Data and config
*.json text
*.yml text
*.yaml text
*.toml text
*.css text
*.scss text
*.html text
*.md text

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.m4a binary
*.mp3 binary
