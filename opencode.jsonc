{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "google-maps": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-google-maps"
      ],
      "env": {
        "GOOGLE_MAPS_API_KEY": "{env:GOOGLE_MAPS_API_KEY}"
      }
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=zmbxriaftswtxjihatfr&read_only=true",
      "enabled": true
    },
    "stripe": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@stripe/mcp"
      ],
      "env": {
        "STRIPE_API_KEY": "{env:STRIPE_SECRET_KEY}",
        "STRIPE_SECRET_KEY": "{env:STRIPE_SECRET_KEY}"
      }
    }
  },
  "provider": {
    "bai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "B.AI",
      "options": {
        "baseURL": "https://api.b.ai/v1",
        "apiKey": "{env:BAI_API_KEY}"
      },
      "models": {
        "gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash (rapido)"
        },
        "glm-5.1": {
          "name": "GLM 5.1 - Zhipu AI (chino)"
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5 - Moonshot AI (chino)"
        }
      }
    }
  }
}
