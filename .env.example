# Supabase Environment Variables
NEXT_PUBLIC_SUPABASE_URL=<your_supabase_url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your_supabase_anon_key>
SUPABASE_SERVICE_ROLE_KEY=<your_supabase_service_role_key>

# Stripe (server-only)
STRIPE_SECRET_KEY=<your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_CHECKOUT_ENABLE_PAYPAL=false
CRON_SECRET=<strong_random_secret_for_vercel_cron>
# IMPORTANT: Do not use Payment Links (https://buy.stripe.com/...) in *_PRICE_ID vars.

# Legacy fallbacks kept for existing deployments only.
STRIPE_PRO_PRICE_ID=<your_legacy_stripe_pro_monthly_price_id>
STRIPE_BUSINESS_PRICE_ID=<your_legacy_stripe_business_monthly_price_id_maps_to_pro>

# Coach IA email whitelist (server-only, comma-separated)
COACH_IA_ALLOWED_EMAILS=user1@example.com,user2@example.com

# PWA Web Push (optional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<your_public_vapid_key>
VAPID_PRIVATE_KEY=<your_private_vapid_key>
VAPID_SUBJECT=mailto:soporte@micuadre.app
LLM_API_KEY=