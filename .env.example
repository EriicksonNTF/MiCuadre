# Supabase Environment Variables
NEXT_PUBLIC_SUPABASE_URL=<your_supabase_url>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your_supabase_anon_key>
SUPABASE_SERVICE_ROLE_KEY=<your_supabase_service_role_key>

# Stripe (server-only)
STRIPE_SECRET_KEY=<your_stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<your_stripe_webhook_secret>
STRIPE_PRO_MONTHLY_PRICE_ID=<your_stripe_pro_monthly_price_id>
STRIPE_PRO_YEARLY_PRICE_ID=<your_stripe_pro_yearly_price_id>

# Legacy fallbacks kept for existing deployments only.
STRIPE_PRO_PRICE_ID=<your_legacy_stripe_pro_monthly_price_id>
STRIPE_BUSINESS_PRICE_ID=<your_legacy_stripe_business_monthly_price_id_maps_to_pro>

# PWA Web Push (optional)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<your_public_vapid_key>
VAPID_PRIVATE_KEY=<your_private_vapid_key>
VAPID_SUBJECT=mailto:soporte@micuadre.app
